---
// PedalDiagram.astro
// Renders a pedal SVG from a pedal definition + settings object.
// Usage:
//   <PedalDiagram pedalId="1991" settings={{ gain1: 75, gain2: 60, ... }} />
//   <PedalDiagram pedalId="scran" settings={{ thick: 60, toggle: "00s", volume: 70 }} />

import { PEDALS } from '../data/site-data.js';
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  pedalId: string;                           // key into PEDALS
  settings: Record<string, number | string>; // knob id -> 0-100, or "00s"/"90s" for toggle
  label?: string;                            // optional song label below pedal
  size?: number;                             // rendered width in px, default 132
}

const { pedalId, settings, label, size = 132 } = Astro.props;
const pedal = PEDALS[pedalId];

// Base64-embed PNG at build time so mix-blend-mode works reliably
let graphicBase64: string | null = null;
if ((pedal.graphicType === 'png' || pedal.graphicType === 'png-direct') && pedal.graphicPng) {
  try {
    // Strip leading slash before joining so path.join doesn't treat it as absolute on Windows
    const relativePath = pedal.graphicPng.replace(/^\//, '');
    const filePath = path.join(process.cwd(), 'public', relativePath);
    graphicBase64 = fs.readFileSync(filePath).toString('base64');
  } catch (e) {
    console.warn(`[PedalDiagram] Could not load PNG for pedal "${pedalId}":`, e.message);
  }
}

// 0-100 -> SVG rotation: 0% = -135deg (CCW), 50% = 0deg (noon), 100% = +135deg (CW)
function pctToRot(pct: number): number {
  return (pct - 50) * 2.7;
}

const TOP_Y    = 40;
const BOTTOM_Y = 95;
const LABEL_BELOW =  26;
const LABEL_ABOVE = -19;

const clipId = `clip-${pedalId}-${label ?? 'x'}`;

// Knob styling — all optional, pedal definition overrides defaults
const knobColor          = pedal.knobColor          ?? '#1c1c1c';
const knobInnerColor     = pedal.knobInnerColor     ?? '#2a2a2a';
const knobOuterR         = pedal.knobOuterR         ?? 14;
const knobInnerR         = pedal.knobInnerR         ?? 10;
const knobStroke         = pedal.knobStroke         ?? '#555';
const knobIndicatorColor = pedal.knobIndicatorColor ?? '#fff';
const knobLabelColor     = pedal.knobLabelColor     ?? '#ddd';
const knobLabelOffset    = pedal.knobLabelOffset    ?? LABEL_BELOW;
const knobTexture        = pedal.knobTexture        ?? false;
const textureAngles      = [0, 45, 90, 135, 180, 225, 270, 315];

// Indicator line positions derived from knob radius
const indY1 = -(knobOuterR - 12); // e.g. r=14 → -2, r=15 → -3
const indY2 = -(knobOuterR - 6);  // e.g. r=14 → -8, r=15 → -9

// Toggle pre-computation
const toggleKnob     = pedal.knobs.find((k: any) => k.type === 'toggle');
const toggleUpValue  = pedal.toggleUpValue ?? '00s';   // which settings value means "up"
const toggleVal      = toggleKnob ? (settings[toggleKnob.id] ?? toggleUpValue) : null;
const toggleIsUp     = toggleVal === toggleUpValue;
const toggleY        = toggleKnob
  ? (toggleKnob.y !== undefined ? toggleKnob.y : BOTTOM_Y)
  : BOTTOM_Y;
const toggleLabel1   = pedal.toggleLabel1 ?? '90s';    // shown when toggle is DOWN
const toggleLabel2   = pedal.toggleLabel2 ?? '00s';    // shown when toggle is UP
const toggleLabelY   = toggleY + 28;                   // position below toggle body
const colorDown      = !toggleIsUp ? '#e8ff47' : 'rgba(255,255,255,0.4)';
const colorUp        = toggleIsUp  ? '#e8ff47' : 'rgba(255,255,255,0.4)';
const fwDown         = !toggleIsUp ? '500' : '400';
const fwUp           = toggleIsUp  ? '500' : '400';
---

<div class="pedal-wrap" style="isolation: auto;">
  {label && <div class="pedal-label">{label}</div>}
  <svg
    width={size}
    height={size * (242/132)}
    viewBox="0 0 132 242"
    xmlns="http://www.w3.org/2000/svg"
    xmlns:xlink="http://www.w3.org/1999/xlink"
  >
    <defs>
      <clipPath id={clipId}>
        <rect x="6" y="6" width="120" height="230" rx="12"/>
      </clipPath>
    </defs>

    <!-- Enclosure base -->
    {pedal.color !== 'none' && (
      <rect x="6" y="6" width="120" height="230" rx="12" fill={pedal.color}/>
    )}

    <!-- PNG direct: transparent PNG rendered as-is, no blend mode -->
    {pedal.graphicType === 'png-direct' && graphicBase64 && (
      <image
        href={`data:image/png;base64,${graphicBase64}`}
        x="6" y="6"
        width="120" height="230"
        clip-path={`url(#${clipId})`}
        preserveAspectRatio="xMidYMid meet"
      />
    )}

    <!-- PNG overlay: must be a direct SVG child (not inside <g>) for multiply blend to work -->
    {pedal.graphicType === 'png' && graphicBase64 && (
      <image
        href={`data:image/png;base64,${graphicBase64}`}
        x="6" y="6"
        width="120" height="230"
        clip-path={`url(#${clipId})`}
        style="mix-blend-mode: multiply; opacity: 0.92;"
        preserveAspectRatio="xMidYMid meet"
      />
    )}

    <!-- Clipped graphic group (text, union-jack, label-box) -->
    <g clip-path={`url(#${clipId})`}>

      <!-- Union Jack (Scran) -->
      {pedal.graphicType === 'union-jack' && (
        <Fragment>
          {/* Blue field */}
          <rect x="6" y="6" width="120" height="230" fill="#012169"/>
          {/* St Andrew white diagonals */}
          <line x1="6" y1="6" x2="126" y2="236" stroke="white" stroke-width="38"/>
          <line x1="126" y1="6" x2="6" y2="236" stroke="white" stroke-width="38"/>
          {/* St Patrick red diagonals */}
          <line x1="6" y1="6" x2="126" y2="236" stroke="#C8102E" stroke-width="22"/>
          <line x1="126" y1="6" x2="6" y2="236" stroke="#C8102E" stroke-width="22"/>
          {/* St George white cross */}
          <rect x="48" y="6" width="36" height="230" fill="white"/>
          <rect x="6" y="101" width="120" height="36" fill="white"/>
          {/* St George red cross */}
          <rect x="54" y="6" width="24" height="230" fill="#C8102E"/>
          <rect x="6" y="107" width="120" height="24" fill="#C8102E"/>
          {/* SCRAN label box */}
          <rect x="18" y="152" width="96" height="28" rx="3" fill="#111"/>
          <rect x="20" y="154" width="92" height="24" rx="2" fill="none" stroke="white" stroke-width="1.5"/>
          <text
            x="66" y="173"
            text-anchor="middle"
            font-family="'Helvetica Neue', Helvetica, Arial, sans-serif"
            font-size="26" font-weight="900" font-style="italic"
            fill="white" letter-spacing="1"
          >scran</text>
        </Fragment>
      )}

      <!-- Text graphic (1991, DIRT, etc.) -->
      {(!pedal.graphicType || pedal.graphicType === 'text') && pedal.graphic && (
        <text
          x="65" y="165"
          text-anchor="middle"
          font-family="'Alumni Sans Collegiate One', Impact, sans-serif"
          font-size="155"
          fill="#111"
          opacity="0.88"
          letter-spacing="2"
          transform="rotate(-90, 66, 121)"
        >{pedal.graphic}</text>
      )}

      <!-- Boss-style pedal -->
      {pedal.graphicType === 'boss' && (
        <Fragment>
          {/* Dark top panel — clip-path handles rounded top corners automatically */}
          <rect x="6" y="6" width="120" height="82" fill={pedal.panelColor ?? '#333030'}/>

          {/* LED — centred near top of dark panel */}
          <circle cx="66" cy="20" r="5" fill="#cc0000" opacity="0.9"/>
          <circle cx="66" cy="20" r="3" fill="#ff5555" opacity="0.8"/>
          <circle cx="66" cy="20" r="1.5" fill="#ffaaaa" opacity="0.6"/>

          {/* Pedal name — centred italic, in cream middle section */}
          <text x="66" y="120" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="10" font-style="italic" font-weight="700" fill={pedal.panelColor ?? '#333030'} letter-spacing="0.2">{pedal.bossName}</text>

          {/* Dark rubber footswitch section — clip-path handles rounded bottom corners */}
          <rect x="6" y="148" width="120" height="88" fill={pedal.panelColor ?? '#333030'}/>
          {/* Inner footswitch raised pad */}
          <rect x="10" y="152" width="112" height="80" rx="8" fill="#3d3a3a"/>
          {/* Subtle top sheen */}
          <rect x="10" y="152" width="112" height="12" rx="8" fill="white" opacity="0.04"/>
        </Fragment>
      )}

      <!-- Floral / JAM Pedals style -->
      {pedal.graphicType === 'floral' && (
        <Fragment>
          {/* Main large daisy — white petals, yellow/orange centre */}
          <g transform="translate(72, 148)">
            {([0, 45, 90, 135, 180, 225, 270, 315] as number[]).map((a: number) => (
              <ellipse cx="0" cy="-25" rx="9" ry="21" fill="white" opacity="0.96" transform={`rotate(${a})`}/>
            ))}
            <circle r="23" fill="#f5d800"/>
            <circle r="15" fill="#e85a0a"/>
            <circle r="7"  fill="#ff2200" opacity="0.9"/>
          </g>

          {/* Small dark flower — left */}
          <g transform="translate(22, 147)">
            {([0, 45, 90, 135, 180, 225, 270, 315] as number[]).map((a: number) => (
              <ellipse cx="0" cy="-14" rx="5" ry="12" fill="#111" transform={`rotate(${a})`}/>
            ))}
            <circle r="11" fill="#f06010"/>
          </g>

          {/* Small orange/red flower — bottom right */}
          <g transform="translate(107, 184)">
            {([0, 40, 80, 120, 160, 200, 240, 280, 320] as number[]).map((a: number) => (
              <ellipse cx="0" cy="-12" rx="5" ry="11" fill="#e02010" transform={`rotate(${a})`}/>
            ))}
            <circle r="11" fill="#f0c010"/>
          </g>

          {/* vibe brand text */}
          <text x="16" y="215" font-family="'Arial Black', Arial, sans-serif" font-size="9" font-weight="900" fill="white" letter-spacing="1" opacity="0.9">vibe</text>

          {/* C / V labels flanking the toggle — C=left (chorus), V=right (vibrato) */}
          {toggleKnob && (
            <Fragment>
              <text x={toggleKnob.x - 14} y={toggleY + 3} text-anchor="middle" font-family="IBM Plex Mono, monospace" font-size="7" font-weight="600" fill={colorUp}   opacity="0.9">C</text>
              <text x={toggleKnob.x + 14} y={toggleY + 3} text-anchor="middle" font-family="IBM Plex Mono, monospace" font-size="7" font-weight="600" fill={colorDown} opacity="0.9">V</text>
            </Fragment>
          )}
        </Fragment>
      )}

      <!-- Label-box graphic (black box + italic text) -->
      {pedal.graphicType === 'label-box' && pedal.graphic && (
        <g transform="translate(66, 140) rotate(-90)">
          <rect x="-48" y="-20" width="96" height="40" rx="3" fill="#111"/>
          <rect x="-44" y="-16" width="88" height="32" rx="2" fill="none" stroke="#fff" stroke-width="1.5"/>
          <text
            x="0" y="6"
            text-anchor="middle"
            font-family="'Helvetica Neue', Helvetica, Arial, sans-serif"
            font-size="22" font-weight="900" font-style="italic"
            fill="#fff" letter-spacing="2"
          >{pedal.graphic}</text>
        </g>
      )}

    </g>

    <!-- Border (drawn after graphic so it sits on top) -->
    {pedal.borderColor !== 'none' && (
      <rect x="6" y="6" width="120" height="230" rx="12" fill="none" stroke={pedal.borderColor} stroke-width="1.5"/>
    )}

    <!-- Knobs (drawn after clipPath group so they sit on top of the flag) -->
    {pedal.knobs.map((knob: any) => {
      if (knob.type === 'toggle') return null;
      const y   = knob.y !== undefined ? knob.y : (knob.row === 'top' ? TOP_Y : BOTTOM_Y);
      const pct = typeof settings[knob.id] === 'number' ? settings[knob.id] as number : 50;
      const rot = pctToRot(pct);
      const lY  = knob.labelPosition === 'above' ? LABEL_ABOVE : knobLabelOffset;
      return (
        <g transform={`translate(${knob.x},${y})`}>
          <circle r={knobOuterR} fill={knobColor} stroke={knobStroke} stroke-width="1.5"/>
          <circle r={knobInnerR} fill={knobInnerColor}/>
          {knobTexture && textureAngles.map((a: number) => (
            <line x1="0" y1="-6" x2="0" y2="-10" stroke="#8a6820" stroke-width="1" opacity="0.5" transform={`rotate(${a})`}/>
          ))}
          <line
            x1="0" y1={indY1} x2="0" y2={indY2}
            stroke={knobIndicatorColor} stroke-width="2" stroke-linecap="round"
            transform={`rotate(${rot})`}
          />
          <text
            x="0" y={lY}
            text-anchor="middle"
            fill={knobLabelColor}
            font-size="7"
            font-family="IBM Plex Mono, monospace"
            font-weight="500"
          >{knob.label}</text>
        </g>
      );
    })}

    <!-- Toggle switch -->
    {toggleKnob && (
      <g transform={`translate(${toggleKnob.x},${toggleY})`}>
        {pedal.toggleOrientation === 'horizontal' ? (
          <Fragment>
            {/* Horizontal body */}
            <rect x="-12" y="-8" width="24" height="16" rx="3" fill="#333" stroke="#555" stroke-width="1"/>
            {/* Left lever (C / chorus) */}
            {toggleIsUp && <rect x="-22" y="-2.5" width="12" height="5" rx="2.5" fill="#bbb" stroke="#999" stroke-width="0.5"/>}
            {toggleIsUp && <circle cx="-22" cy="0" r="3.5" fill="#ddd" stroke="#aaa" stroke-width="0.5"/>}
            {/* Right lever (V / vibrato) */}
            {!toggleIsUp && <rect x="10" y="-2.5" width="12" height="5" rx="2.5" fill="#bbb" stroke="#999" stroke-width="0.5"/>}
            {!toggleIsUp && <circle cx="22" cy="0" r="3.5" fill="#ddd" stroke="#aaa" stroke-width="0.5"/>}
          </Fragment>
        ) : (
          <Fragment>
            {/* Vertical body */}
            <rect x="-8" y="-12" width="16" height="24" rx="3" fill="#333" stroke="#555" stroke-width="1"/>
            {toggleIsUp && <rect x="-2.5" y="-18" width="5" height="14" rx="2.5" fill="#bbb" stroke="#999" stroke-width="0.5"/>}
            {toggleIsUp && <circle cx="0" cy="-19" r="3.5" fill="#ddd" stroke="#aaa" stroke-width="0.5"/>}
            {!toggleIsUp && <rect x="-2.5" y="4" width="5" height="14" rx="2.5" fill="#bbb" stroke="#999" stroke-width="0.5"/>}
            {!toggleIsUp && <circle cx="0" cy="19" r="3.5" fill="#ddd" stroke="#aaa" stroke-width="0.5"/>}
          </Fragment>
        )}
      </g>
    )}

    <!-- Toggle era labels (suppressed when pedal.hideToggleLabels is true) -->
    {!pedal.hideToggleLabels && toggleKnob && (
      <Fragment>
        <text x={toggleKnob.x - 12} y={toggleLabelY} text-anchor="middle" fill={colorDown} font-size="6" font-family="IBM Plex Mono, monospace" font-weight={fwDown}>▼ {toggleLabel1}</text>
        <text x={toggleKnob.x + 12} y={toggleLabelY} text-anchor="middle" fill={colorUp}   font-size="6" font-family="IBM Plex Mono, monospace" font-weight={fwUp}>{toggleLabel2} ▲</text>
      </Fragment>
    )}

    <!-- Footswitch -->
    {!pedal.hideFootswitch && (
      <Fragment>
        <circle cx="66" cy="206" r="18" fill="#e0e0e0" stroke="#bbb" stroke-width="2"/>
        <circle cx="66" cy="206" r="7" fill="#999"/>
      </Fragment>
    )}
  </svg>
</div>

<style>
  .pedal-wrap { display: inline-block; text-align: center; }
  .pedal-label {
    color: #666;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 10px;
    font-family: 'IBM Plex Mono', monospace;
  }
</style>
