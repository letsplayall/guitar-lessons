---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PedalDiagram from '../../components/PedalDiagram.astro';
import { TONE_SETTINGS } from '../../data/site-data.js';

const bands = Object.entries(TONE_SETTINGS);
---

<BaseLayout title="Tone Settings" description="Exact pedal settings for grunge and alt-rock songs — Funny Little Boxes 1991 and Dirt knob positions per song.">
  <style>
    .page-header {
      padding: 64px 24px 48px;
      border-bottom: 1px solid var(--border);
      background:
        radial-gradient(ellipse 40% 80% at 100% 50%, rgba(249,194,49,0.07) 0%, transparent 70%),
        var(--bg);
    }
    .page-header-inner {
      max-width: 1200px;
      margin: 0 auto;
    }
    .page-eyebrow {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
    }
    .page-title {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(2.5rem, 5vw, 4rem);
      letter-spacing: -0.01em;
      line-height: 0.92;
      text-transform: uppercase;
      color: var(--text);
      margin-bottom: 16px;
    }
    .page-desc {
      font-family: var(--font-body);
      font-size: 15px;
      color: var(--muted2);
      line-height: 1.7;
      max-width: 520px;
    }

    /* Pedal legend */
    .pedal-legend {
      display: flex;
      gap: 16px;
      margin-top: 28px;
      flex-wrap: wrap;
    }
    .pedal-badge {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 6px 12px;
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--muted2);
    }
    .pedal-badge .dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* Content */
    .content {
      max-width: 1200px;
      margin: 0 auto;
      padding: 64px 24px 80px;
    }

    .band-block { margin-bottom: 72px; }

    .band-heading {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 28px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--border);
    }
    .band-name {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      letter-spacing: -0.01em;
      line-height: 1;
      text-transform: uppercase;
      color: var(--text);
    }
    .band-count {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* Song rows */
    .song-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 40px;
      align-items: start;
      padding: 28px 0;
      border-bottom: 1px solid var(--border);
    }
    .song-info {}
    .song-title {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 1.35rem;
      letter-spacing: -0.01em;
      text-transform: uppercase;
      color: var(--text);
      margin-bottom: 8px;
    }
    .song-notes {
      font-family: var(--font-body);
      font-size: 13px;
      color: var(--muted);
      line-height: 1.7;
      margin-top: 10px;
      max-width: 420px;
    }
    .song-notes::before {
      content: '// ';
      font-family: var(--font-mono);
      color: var(--muted);
      opacity: 0.5;
    }
    .pedals-row {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    /* Knob value callout */
    .knob-note {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--muted);
      margin-top: 6px;
      text-align: center;
      letter-spacing: 0.05em;
    }

    @media (max-width: 640px) {
      .song-row { grid-template-columns: 1fr; }
      .pedals-row { justify-content: flex-start; }
    }

    /* ── BAND FILTER BAR ── */
    .band-filter-bar {
      position: sticky;
      top: 80px;
      z-index: 100;
      background: rgba(10,10,10,0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
    }
    .band-filter-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 10px 0;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .band-filter-inner::-webkit-scrollbar { display: none; }
    .filter-btn {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      white-space: nowrap;
      padding: 5px 12px;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--muted);
      cursor: pointer;
      transition: color 0.12s ease, border-color 0.12s ease, background 0.12s ease;
      flex-shrink: 0;
    }
    .filter-btn:hover { color: var(--text); border-color: rgba(255,255,255,0.2); }
    .filter-btn.active { color: #f9c231; border-color: #f9c231; background: rgba(249,194,49,0.07); }
    .filter-btn:focus-visible { outline: 2px solid var(--red); outline-offset: 2px; }
  </style>

  <div class="page-header">
    <div class="page-header-inner">
      <div class="page-eyebrow">
        <span class="red-rule"></span>
        <span class="label">Tone Settings - Work In Progress!</span>
      </div>
      <h1 class="page-title">How I get<br/>the tones</h1>
      <p class="page-desc">
        Pedal settings per song. I generally set my amp right on the edge of breakup. Your amp and guitar will vary, but this should get you close.
      </p>
    </div>
  </div>

  <!-- BAND FILTER BAR -->
  {bands.length > 1 && (
    <div class="band-filter-bar">
      <div class="band-filter-inner">
        <button class="filter-btn active" data-band="">All</button>
        {bands.map(([band]) => (
          <button class="filter-btn" data-band={band}>{band}</button>
        ))}
      </div>
    </div>
  )}

  <div class="content">
    {bands.map(([band, songs]) => {
      const songCount = Object.keys(songs).length;
      const slug = band.toLowerCase().replace(/[^a-z0-9]+/g, '-');
      return (
        <div class="band-block" id={`band-${slug}`} data-band={band}>
          <div class="band-heading">
            <div class="band-name">{band}</div>
            <div class="band-count">{songCount} {songCount === 1 ? 'song' : 'songs'}</div>
          </div>
          {Object.entries(songs).map(([song, data]) => (
            <div class="song-row">
              <div class="song-info">
                <div class="song-title">{song}</div>
                {data.notes && <div class="song-notes">{data.notes}</div>}
              </div>
              <div class="pedals-row">
                {data.pedals.map((p) => (
                  <div style="text-align:center;">
                    <PedalDiagram
                      pedalId={p.pedal}
                      settings={p.settings}
                      size={120}
                    />
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      );
    })}
  </div>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const bandBlocks = document.querySelectorAll('.band-block');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const selected = btn.dataset.band;

      // Update active state
      filterBtns.forEach(b => b.classList.toggle('active', b === btn));

      if (!selected) {
        // Show all
        bandBlocks.forEach(block => block.style.display = '');
      } else {
        bandBlocks.forEach(block => {
          block.style.display = block.dataset.band === selected ? '' : 'none';
        });
        // Scroll to band, accounting for nav + filter bar
        const target = document.querySelector(`.band-block[data-band="${selected}"]`);
        if (target) {
          const navHeight = document.querySelector('.site-nav-wrap')?.offsetHeight ?? 80;
          const filterHeight = document.querySelector('.band-filter-bar')?.offsetHeight ?? 0;
          const offset = target.getBoundingClientRect().top + window.scrollY - navHeight - filterHeight - 12;
          window.scrollTo({ top: offset, behavior: 'smooth' });
        }
      }
    });
  });
</script>

</BaseLayout>
